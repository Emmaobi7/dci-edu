// Prisma schema for the LMS
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(STUDENT)
  disabledAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Profile fields (nullable; populated via /api/me/profile)
  firstName            String?
  surname              String?
  title                String?
  phone                String?
  country              String?
  placeOfWork          String?
  positionAtWapcp      String?
  matriculationNumber  String? @unique
  topics               String?
  avatarStoredName     String?
  avatarMimetype       String?

  ownedClassrooms   Classroom[]  @relation("ClassroomTeacher")
  moderatedClassrooms Classroom[] @relation("ClassroomModerator")
  enrolments        Enrolment[]
  createdAssignments Assignment[] @relation("AssignmentAuthor")
  submissions       Submission[]
  gradedSubmissions Submission[] @relation("SubmissionGrader")
  announcements     Announcement[] @relation("AnnouncementAuthor")
  comments          AnnouncementComment[] @relation("AnnouncementCommentAuthor")
  notifications     Notification[] @relation("NotificationRecipient")
  createdQuizzes    Quiz[]                @relation("QuizAuthor")
  quizAttempts      QuizAttempt[]
  sentMessages      Message[]             @relation("MessageSender")
  deletedMessages   Message[]             @relation("MessageDeleter")
  createdEvents     Event[]               @relation("EventAuthor")
  createdResources  Resource[]            @relation("ResourceAuthor")
  auditEventsAuthored AuditEvent[]        @relation("AuditEventActor")
  auditEventsTargeting AuditEvent[]       @relation("AuditEventTargetUser")
  passwordResetTokens PasswordResetToken[]

  @@index([role])
  @@index([disabledAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Classroom {
  id          String   @id @default(cuid())
  name        String
  description String?
  code        String   @unique
  teacherId   String
  teacher     User     @relation("ClassroomTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  moderatorId String?
  moderator   User?    @relation("ClassroomModerator", fields: [moderatorId], references: [id], onDelete: SetNull)
  enrolments  Enrolment[]
  assignments Assignment[]
  announcements Announcement[]
  notifications Notification[]
  quizzes     Quiz[]
  messages    Message[]
  events      Event[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teacherId])
  @@index([moderatorId])
}

model Enrolment {
  id          String   @id @default(cuid())
  classroomId String
  studentId   String
  mutedAt     DateTime?
  joinedAt    DateTime @default(now())

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classroomId, studentId])
  @@index([studentId])
}

model Message {
  id           String    @id @default(cuid())
  classroomId  String
  senderId     String
  body         String
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?
  deletedById  String?

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  sender    User      @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  deletedBy User?     @relation("MessageDeleter", fields: [deletedById], references: [id], onDelete: SetNull)

  @@index([classroomId, createdAt])
  @@index([senderId])
}


model Assignment {
  id          String   @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  classroomId String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  classroom   Classroom             @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  createdBy   User                  @relation("AssignmentAuthor", fields: [createdById], references: [id], onDelete: Cascade)
  attachments AssignmentAttachment[]
  submissions Submission[]
  notifications Notification[]

  @@index([classroomId])
  @@index([createdById])
}

model AssignmentAttachment {
  id            String     @id @default(cuid())
  assignmentId  String
  filename      String
  storedName    String
  mimetype      String
  size          Int
  createdAt     DateTime   @default(now())

  assignment    Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
}

model Submission {
  id           String   @id @default(cuid())
  assignmentId String
  studentId    String
  filename     String
  storedName   String
  mimetype     String
  size         Int
  isLate       Boolean  @default(false)
  grade        Int?
  feedback     String?
  gradedAt     DateTime?
  gradedById   String?
  submittedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  gradedBy   User?      @relation("SubmissionGrader", fields: [gradedById], references: [id], onDelete: SetNull)

  @@unique([assignmentId, studentId])
  @@index([studentId])
}

enum AttachmentKind {
  IMAGE
  YOUTUBE
  DOCUMENT
  LINK
}

enum NotificationType {
  ANNOUNCEMENT_NEW
  ASSIGNMENT_NEW
  COMMENT_NEW
  QUIZ_NEW
  EVENT_NEW
}

enum EventType {
  EVENT
  CLASS_SESSION
}

model Announcement {
  id          String   @id @default(cuid())
  classroomId String
  authorId    String
  body        String
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  classroom   Classroom                @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  author      User                     @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  attachments AnnouncementAttachment[]
  comments    AnnouncementComment[]
  notifications Notification[]

  @@index([classroomId])
  @@index([authorId])
}

model AnnouncementAttachment {
  id             String         @id @default(cuid())
  announcementId String
  kind           AttachmentKind

  // For IMAGE and DOCUMENT
  filename       String?
  storedName     String?
  mimetype       String?
  size           Int?

  // For YOUTUBE
  youtubeId      String?
  youtubeUrl     String?

  // For LINK (and mirrored for YOUTUBE)
  url            String?
  title          String?
  host           String?

  createdAt      DateTime       @default(now())

  announcement   Announcement   @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@index([announcementId])
}

model AnnouncementComment {
  id             String       @id @default(cuid())
  announcementId String
  authorId       String
  body           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  author         User         @relation("AnnouncementCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([announcementId])
  @@index([authorId])
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  type           NotificationType
  classroomId    String?
  announcementId String?
  assignmentId   String?
  quizId         String?
  eventId        String?
  title          String
  body           String?
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  user           User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  classroom      Classroom?       @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  announcement   Announcement?    @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  assignment     Assignment?      @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  quiz           Quiz?            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  event          Event?           @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model Event {
  id          String    @id @default(cuid())
  type        EventType @default(EVENT)
  title       String
  description String?
  location    String?
  meetingUrl  String?
  startsAt    DateTime
  endsAt      DateTime?
  classroomId String?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  classroom     Classroom?     @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  createdBy     User           @relation("EventAuthor", fields: [createdById], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([classroomId, startsAt])
  @@index([startsAt])
  @@index([createdById])
}

model Quiz {
  id               String   @id @default(cuid())
  classroomId      String
  createdById      String
  title            String
  description      String?
  timeLimitMinutes Int?
  dueDate          DateTime?
  shuffleQuestions Boolean  @default(false)
  shuffleOptions   Boolean  @default(true)
  showAnswers      Boolean  @default(true)
  questions        Json
  totalPoints      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  classroom        Classroom     @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  createdBy        User          @relation("QuizAuthor", fields: [createdById], references: [id], onDelete: Cascade)
  attempts         QuizAttempt[]
  notifications    Notification[]

  @@index([classroomId])
  @@index([createdById])
}

model QuizAttempt {
  id            String    @id @default(cuid())
  quizId        String
  studentId     String
  startedAt     DateTime  @default(now())
  submittedAt   DateTime?
  isLate        Boolean   @default(false)
  questionOrder Json
  optionOrders  Json
  answers       Json
  score         Int?
  totalPoints   Int

  quiz    Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([quizId, studentId])
  @@index([studentId])
}

enum AuditAction {
  USER_CREATED
  USER_ROLE_CHANGED
  USER_PASSWORD_RESET
  USER_DISABLED
  USER_ENABLED
  USER_IMPORTED
  CLASSROOM_DELETED
  RESOURCE_CREATED
  RESOURCE_DELETED
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User                 @relation("ResourceAuthor", fields: [createdById], references: [id], onDelete: Cascade)
  attachments ResourceAttachment[]

  @@index([createdById])
  @@index([category])
  @@index([createdAt])
}

model ResourceAttachment {
  id         String         @id @default(cuid())
  resourceId String
  kind       AttachmentKind

  // For IMAGE and DOCUMENT
  filename   String?
  storedName String?
  mimetype   String?
  size       Int?

  // For YOUTUBE
  youtubeId  String?
  youtubeUrl String?

  // For LINK (and mirrored for YOUTUBE)
  url        String?
  title      String?
  host       String?

  createdAt  DateTime @default(now())

  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId])
}

model AuditEvent {
  id            String      @id @default(cuid())
  action        AuditAction
  actorId       String
  targetUserId  String?
  targetType    String?
  targetId      String?
  summary       String
  metadata      Json?
  createdAt     DateTime    @default(now())

  actor       User  @relation("AuditEventActor", fields: [actorId], references: [id], onDelete: Cascade)
  targetUser  User? @relation("AuditEventTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorId])
  @@index([targetUserId])
  @@index([action])
}
