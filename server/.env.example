# server runtime
NODE_ENV=development
PORT=4000

# postgres (Neon)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# auth
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d
COOKIE_NAME=wapcharm_token

# cors
CLIENT_ORIGIN=http://localhost:5173

# uploads
MAX_UPLOAD_BYTES=10485760

# supabase storage
# Project Settings -> API: copy "Project URL" and the "service_role" key.
# Storage -> create a bucket named below (or change to your bucket name).
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_BUCKET=wapcharm

# outbound email (Brevo SMTP relay)
# SMTP creds from Brevo dashboard -> SMTP & API -> SMTP tab.
# MAIL_FROM must use a domain you have verified as a sender in Brevo.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-smtp-login@example.com
SMTP_PASS=your-brevo-smtp-key
MAIL_FROM=WAPCPharm Classroom <noreply@yourdomain.com>

# Public base URL used to build links in outbound emails (e.g. reset-password link).
APP_BASE_URL=http://localhost:5173
