# Client environment.
#
# In development, leave VITE_API_URL unset so the Vite dev server proxies
# /api and /socket.io to http://localhost:4000 (see vite.config.ts).
#
# In production, set VITE_API_URL to the absolute API base URL, e.g.:
#   VITE_API_URL=https://wapcharm-api.onrender.com/api
#
# The Socket.IO client connects to the API origin derived from this value
# (the /api suffix is stripped for the WebSocket handshake).
#VITE_API_URL=
