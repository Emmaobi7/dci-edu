{
  "name": "wapcharm",
  "private": true,
  "version": "0.0.1",
  "description": "LMS monorepo (client + server)",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "build": "npm --workspace server run build && npm --workspace client run build",
    "lint": "npm --workspace server run lint && npm --workspace client run lint"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
